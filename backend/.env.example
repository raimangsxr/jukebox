# jukebox-backend environment variables (flat JUKEBOX_ prefix).

JUKEBOX_DATABASE_URL=postgresql+psycopg://jukebox:jukebox@localhost:5432/jukebox
JUKEBOX_CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:4200

JUKEBOX_OPERATOR_USERNAME=op
JUKEBOX_OPERATOR_PASSWORD=change-me-please-1234

JUKEBOX_SESSION_SECRET=dev-only-change-me-with-openssl-rand-hex-32
JUKEBOX_COOKIE_SECURE=false
JUKEBOX_FRAME_ANCESTORS='none'
JUKEBOX_MAX_PENDING_SUBMISSIONS_PER_PARTICIPANT=2
